extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block main 
  .container.my-3
    .row 
      .col-12
        +box-head(pageTitle)

    .row 
      each item in categories 
        .col-6.mb-3
          .card 
            img(src=item.image, style="height: 218.95px; width: 100%; object-fit: cover")
            .card-body
              h5.card-title #{item.title}
              a(href=`/tours/${item.slug}` class="btn btn-primary") Xem chi tiết